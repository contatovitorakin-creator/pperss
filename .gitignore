```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Build and distribution directories
dist/
build/
target/
*.egg-info/

# Python specific
*.pyo
*.pyd
*.so
*.dylib

# Compression and archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```